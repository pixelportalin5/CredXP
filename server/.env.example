# =============================================================================
# CredXP API — Environment contract (Phase 1)
# Copy to .env and fill in values. Never commit .env.
# =============================================================================

# --- Runtime ---
NODE_ENV=development
PORT=5000

# --- MongoDB (current primary — unchanged in Phase 1) ---
MONGODB_URI=mongodb://localhost:27017/credxp

# --- Neon PostgreSQL (dual-run preparation) ---
# Neon dev branch connection string (pooled recommended for serverless/VPS)
# Example: postgresql://user:pass@ep-xxx.region.aws.neon.tech/credxp?sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@HOST/credxp?sslmode=require

# --- Database provider (Phase 4 — default mongo, production unchanged) ---
DB_PROVIDER=mongo

# --- Dual-run flags (Phase 3+) ---
# Which database answers reads/writes once services are migrated
DB_PRIMARY=mongo
# Enable shadow writes to PostgreSQL during dual-run (Phase 3+)
DB_DUAL_WRITE=false
# Log Prisma query timing in development
PRISMA_LOG_QUERIES=false

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# --- CORS / URLs ---
CLIENT_URL=http://localhost:3000
API_PUBLIC_URL=http://localhost:5000

# --- Proposal PDF (Puppeteer) ---
# Shared secret between API and Next.js export page (must match client PDF_EXPORT_SECRET)
PDF_EXPORT_SECRET=change-me-to-a-long-random-string
# Optional: path to Chromium when not using bundled Puppeteer (production Docker/Render)
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser

# --- Cloudinary (Phase 2 — image storage) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Optional: external APIs ---
# INSIGHTS_RSS_URL=
