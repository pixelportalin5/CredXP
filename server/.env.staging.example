# =============================================================================
# CredXP — Staging / local PostgreSQL cutover validation (Phase 5A)
# Copy to .env.staging or merge into local .env. Never commit secrets.
# Production must keep DB_PROVIDER=mongo until cutover is approved.
# =============================================================================

NODE_ENV=development
PORT=5000

# MongoDB (still required for dual-run / migration tooling)
MONGODB_URI=mongodb://localhost:27017/credxp

# Neon PostgreSQL (migrated data must exist — run migrate:mongo-to-postgres first)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Phase 5A — use PostgreSQL for all factory-resolved services
DB_PROVIDER=postgres

JWT_SECRET=change-me
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:3000

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional: validate login flow in phase5a script
# PHASE5A_TEST_EMAIL=admin@example.com
# PHASE5A_TEST_PASSWORD=your-test-password

# Staging smoke test (validate:staging-smoke)
# STAGING_API_URL=http://127.0.0.1:5000/api
# STAGING_APP_URL=http://127.0.0.1:3000
# DEPLOYED_APP_URL=https://credxp-mvp.vercel.app
# STAGING_TEST_EMAIL=admin@example.com
# STAGING_TEST_PASSWORD=your-test-password
