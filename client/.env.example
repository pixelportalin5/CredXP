# =============================================================================
# CredXP Web — Environment contract (Phase 1)
# Copy to .env.local and fill in values. Never commit secrets.
# =============================================================================

# --- API ---
NEXT_PUBLIC_API_URL=http://localhost:5000/api
# Default 30000 — raise if Render cold starts exceed this (ms)
# NEXT_PUBLIC_API_TIMEOUT_MS=30000

# --- App URLs (used for links, QR codes, previews) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Proposal PDF export (server-side Puppeteer) ---
# Must match PDF_EXPORT_SECRET on the Express server
PDF_EXPORT_SECRET=change-me-to-a-long-random-string
# Optional: internal API URL for Next.js server components (defaults to NEXT_PUBLIC_API_URL)
# INTERNAL_API_URL=http://localhost:5000/api

# --- Feature flags (migration phases) ---
# Images upload via POST /api/uploads/image (Cloudinary). Legacy base64 still renders.
NEXT_PUBLIC_USE_CLOUDINARY_UPLOADS=true

# --- Optional analytics / monitoring (Phase 5+) ---
# NEXT_PUBLIC_SENTRY_DSN=
